generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum Role {
  SUPER_ADMIN
  ADMIN
  TUTOR
  PARENT
  CONSULTANT
}

enum Permission {
  USER_MANAGEMENT
  TUTOR_MANAGEMENT
  COURSE_MANAGEMENT
  BOOKING_OVERSIGHT
  PAYMENT_MANAGEMENT
  CREDIT_MANAGEMENT
  TUTOR_PAYOUTS
  CMS_MANAGEMENT
  ANALYTICS_ACCESS
  SYSTEM_CONFIG
}

enum DemoRequestStatus {
  PENDING
  ASSIGNED
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum TimeSlotPreference {
  MORNING
  AFTERNOON
  EVENING
}

enum DemoBookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum EnrollmentStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

enum ClassType {
  ONE_TO_ONE
  GROUP
}

enum SessionStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED_PARENT
  CANCELLED_LATE
  SKIPPED
  NO_SHOW_REPORTED
  MISSED_TUTOR
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ApplicationRole {
  TUTOR
  CONSULTANT
}

// ============================================
// TUTOR / CONSULTANT APPLICATION
// ============================================

model Application {
  id        String            @id @default(uuid())
  role      ApplicationRole
  status    ApplicationStatus @default(PENDING)

  // Personal info
  firstName String
  lastName  String
  email     String
  phone     String

  // Professional info
  experience   Int       @default(0) // years
  bio          String?
  resumeUrl    String?
  subjects     String?   // comma-separated subject names (free text from applicant)
  qualifications String? // degrees, certifications, etc.

  // Admin review
  reviewedBy String?   // admin user ID who reviewed
  reviewNote String?   // admin's internal note
  reviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([role])
  @@index([email])
  @@index([createdAt])
}

// ============================================
// M1: USER & AUTHENTICATION
// ============================================

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  passwordHash        String
  role                Role
  isActive            Boolean   @default(true)
  isEmailVerified     Boolean   @default(false)
  forcePasswordChange Boolean   @default(false)
  lastLoginAt         DateTime?
  timezone            String    @default("Asia/Dubai") // IANA timezone (e.g. "Asia/Kolkata", "Asia/Dubai")

  // Role-specific profiles
  parentProfile     ParentProfile?
  tutorProfile      TutorProfile?
  consultantProfile ConsultantProfile?

  // Admin permissions (only for SUPER_ADMIN and ADMIN)
  adminPermissions AdminPermission[]

  // Tokens (refresh, verification, reset)
  tokens Token[]

  // V2: Student self-access
  studentAccount Student?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([email])
  @@index([role])
  @@index([isActive])
}

model AdminPermission {
  id         String     @id @default(uuid())
  userId     String
  permission Permission

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, permission])
  @@index([userId])
}

// ============================================
// TOKEN STORAGE (replaces Redis)
// ============================================

enum TokenType {
  REFRESH
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model Token {
  id        String    @id @default(uuid())
  userId    String
  type      TokenType
  value     String    @unique
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([value])
  @@index([userId, type])
  @@index([expiresAt])
}

// ============================================
// M2: PARENT & STUDENT PROFILES
// ============================================

model ParentProfile {
  id        String  @id @default(uuid())
  userId    String  @unique
  firstName String
  lastName  String
  phone     String?
  address   String?
  city      String?
  country   String  @default("UAE")

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  children     Student[]
  demoRequests DemoRequest[]
  creditTransactions CreditTransaction[]
  enrollments  Enrollment[]
  payments     Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Student {
  id          String    @id @default(uuid())
  parentId    String
  userId      String?   @unique
  firstName   String
  lastName    String
  dateOfBirth DateTime?
  gradeId     String
  notes       String?

  parent ParentProfile @relation(fields: [parentId], references: [id], onDelete: Cascade)
  user   User?         @relation(fields: [userId], references: [id])
  grade  GradeLevel    @relation(fields: [gradeId], references: [id])

  subjectNeeds   StudentSubject[]
  demoBookings   DemoBooking[]
  enrollments    Enrollment[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([parentId])
  @@index([gradeId])
}

model StudentSubject {
  id        String @id @default(uuid())
  studentId String
  subjectId String

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([studentId, subjectId])
}

// ============================================
// M2: TUTOR PROFILE
// ============================================

model TutorProfile {
  id              String  @id @default(uuid())
  userId          String  @unique
  firstName       String
  lastName        String
  phone           String?
  bio             String?
  experience      Int     @default(0)
  profilePhotoUrl String?
  introVideoUrl   String?
  isActive        Boolean @default(true)
  noShowStrikes   Int     @default(0)
  lastStrikeAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  certifications TutorCertification[]
  courses        TutorCourse[]

  // M5: Availability
  availabilityTemplates AvailabilityTemplate[]
  blockedDates          BlockedDate[]

  // M6: Demo Bookings
  demoBookings  DemoBooking[]
  enrollments   Enrollment[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([isActive])
}

model TutorCertification {
  id          String  @id @default(uuid())
  tutorId     String
  title       String
  institution String?
  year        Int?
  documentUrl String

  tutor TutorProfile @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([tutorId])
}

// ============================================
// M2: CONSULTANT PROFILE
// ============================================

model ConsultantProfile {
  id        String  @id @default(uuid())
  userId    String  @unique
  firstName String
  lastName  String
  phone     String?
  email     String?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  demoRequests DemoRequest[]
  demoBookings  DemoBooking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// M4: SUBJECT & GRADE (Reference tables — needed by M2)
// ============================================

model Subject {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  isActive    Boolean @default(true)

  studentNeeds        StudentSubject[]
  demoRequestSubjects DemoRequestSubject[]
  courses             Course[]
  demoBookings        DemoBooking[]
  enrollments         Enrollment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model GradeLevel {
  id        String @id @default(uuid())
  name      String @unique
  sortOrder Int    @unique
  tierId    String

  tier         GradeTier     @relation(fields: [tierId], references: [id])
  students     Student[]
  demoRequests DemoRequest[]
  courses      Course[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@index([tierId])
}

model GradeTier {
  id              String @id @default(uuid())
  name            String @unique
  creditsPerClass Int           // Legacy fallback
  credits60Min    Int    @default(0)
  credits90Min    Int    @default(0)
  credits120Min   Int    @default(0)
  minGrade        Int
  maxGrade        Int

  gradeLevels GradeLevel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// M5: AVAILABILITY & SCHEDULING
// ============================================

model AvailabilityTemplate {
  id        String @id @default(uuid())
  tutorId   String
  dayOfWeek Int    // 0=Sunday, 1=Monday, ..., 6=Saturday
  startTime String // "HH:mm" in 24hr format
  endTime   String // "HH:mm" in 24hr format

  tutor TutorProfile @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([tutorId, dayOfWeek, startTime, endTime])
  @@index([tutorId])
  @@index([dayOfWeek])
}

model BlockedDate {
  id      String   @id @default(uuid())
  tutorId String
  date    DateTime @db.Date
  reason  String?

  tutor TutorProfile @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([tutorId, date])
  @@index([tutorId])
}

// ============================================
// M4: BOARD (Reference table)
// ============================================

model Board {
  id       String  @id @default(uuid())
  name     String  @unique
  isActive Boolean @default(true)

  demoRequests DemoRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

// ============================================
// M6: DEMO REQUEST
// ============================================

model DemoRequest {
  id         String  @id @default(uuid())
  parentId   String?
  parentName String  // Stores name from public form (no account needed)

  // Contact info
  contactEmail String
  contactPhone String

  // Child info as text (admin creates child profile later)
  childFirstName   String
  childLastName    String
  childDateOfBirth DateTime?

  // References
  boardId String
  gradeId String

  // Scheduling
  preferredTimeSlot TimeSlotPreference
  preferredDate     DateTime           @db.Date
  alternativeDate   DateTime?          @db.Date

  // Notes
  notes String?

  // Status & assignment
  status       DemoRequestStatus  @default(PENDING)
  consultantId String?

  // Relations
  parent      ParentProfile?     @relation(fields: [parentId], references: [id], onDelete: Cascade)
  board       Board              @relation(fields: [boardId], references: [id])
  grade       GradeLevel         @relation(fields: [gradeId], references: [id])
  consultant  ConsultantProfile? @relation(fields: [consultantId], references: [id])
  subjects    DemoRequestSubject[]
  demoBooking DemoBooking?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([status])
  @@index([consultantId])
  @@index([createdAt])
  @@index([contactEmail])
}

model DemoRequestSubject {
  id            String @id @default(uuid())
  demoRequestId String
  subjectId     String

  demoRequest DemoRequest @relation(fields: [demoRequestId], references: [id], onDelete: Cascade)
  subject     Subject     @relation(fields: [subjectId], references: [id])

  @@unique([demoRequestId, subjectId])
}

// ============================================
// M4: COURSE & COURSE MATERIALS
// ============================================

model Course {
  id          String    @id @default(uuid())
  subjectId   String
  gradeId     String
  name        String    // e.g., "Mathematics — Grade 10"
  description String?
  isActive    Boolean   @default(true)

  subject   Subject    @relation(fields: [subjectId], references: [id])
  grade     GradeLevel @relation(fields: [gradeId], references: [id])
  tutors    TutorCourse[]
  materials CourseMaterial[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([subjectId, gradeId])
  @@index([subjectId])
  @@index([gradeId])
  @@index([isActive])
}

model TutorCourse {
  id        String @id @default(uuid())
  tutorId   String
  courseId   String
  tutorRate Int    // Rate in fils per class (1 AED = 100 fils)

  tutor  TutorProfile @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  course Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([tutorId, courseId])
  @@index([tutorId])
  @@index([courseId])
}

model CourseMaterial {
  id         String @id @default(uuid())
  courseId    String
  title      String
  fileUrl    String
  fileType   String // pdf, docx, etc.
  fileSizeKb Int?

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([courseId])
}

// ============================================
// M8: CREDIT WALLET SYSTEM
// ============================================

enum CreditTransactionType {
  PURCHASE
  DEDUCTION
  ADMIN_ADJUSTMENT
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  EXPIRED
}

model CreditPackage {
  id        String  @id @default(uuid())
  name      String  @unique
  credits   Int
  priceInFils Int   // 1 AED = 100 fils
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  payments  Payment[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([isActive])
}

model CreditTransaction {
  id             String                @id @default(uuid())
  parentId       String
  type           CreditTransactionType
  amount         Int                   // Positive always — direction determined by type
  description          String?
  enrollmentSessionId  String?               @unique
  paymentId            String?               @unique

  parent             ParentProfile      @relation(fields: [parentId], references: [id], onDelete: Cascade)
  enrollmentSession  EnrollmentSession? @relation(fields: [enrollmentSessionId], references: [id])
  payment            Payment?           @relation(fields: [paymentId], references: [id])

  createdAt DateTime @default(now())

  // Immutable ledger — no updatedAt, no deletedAt

  @@index([parentId])
  @@index([type])
  @@index([createdAt])
}

// ============================================
// M6: DEMO BOOKING (Scheduled demo class)
// ============================================

model DemoBooking {
  id            String  @id @default(uuid())
  demoRequestId String? @unique
  studentId     String?
  tutorId       String
  consultantId  String
  subjectId     String
  status        DemoBookingStatus @default(PENDING)

  // Scheduling (V1: manual, no slot system)
  scheduledDate  DateTime @db.Date
  scheduledStart String   // "HH:mm" in 24hr format
  scheduledEnd   String   // "HH:mm" in 24hr format

  // Meeting
  meetingLink     String?
  meetingPassword String?
  zoomMeetingId   BigInt?

  // Notes
  parentNotes     String?
  consultantNotes String?

  // Relations
  demoRequest DemoRequest?      @relation(fields: [demoRequestId], references: [id])
  student     Student?          @relation(fields: [studentId], references: [id])
  tutor       TutorProfile      @relation(fields: [tutorId], references: [id])
  consultant  ConsultantProfile @relation(fields: [consultantId], references: [id])
  subject     Subject           @relation(fields: [subjectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tutorId])
  @@index([consultantId])
  @@index([status])
  @@index([scheduledDate])
}

// ============================================
// M7: ENROLLMENT (Recurring paid classes)
// ============================================

model Enrollment {
  id               String           @id @default(uuid())
  studentId        String
  parentId         String
  subjectId        String
  tutorId          String
  status           EnrollmentStatus @default(ACTIVE)
  classType        ClassType        @default(ONE_TO_ONE)

  // Schedule: JSON array of { dayOfWeek: number, startTime: "HH:mm" }
  schedule         Json             // e.g. [{ dayOfWeek: 1, startTime: "16:00" }, { dayOfWeek: 3, startTime: "17:00" }]
  duration         Int              // Duration in minutes (60, 90, or 120)

  // Meeting (one Zoom link per enrollment)
  zoomLink         String?
  zoomPassword     String?
  zoomMeetingId    BigInt?

  // Timezone snapshot (immutable — taken from parent at enrollment creation)
  timezone         String           @default("Asia/Dubai")

  // Credits
  creditsPerSession Int             // Snapshot from GradeTier at enrollment time

  // Rolling session generation tracking
  lastGeneratedDate DateTime?       // Last date for which sessions were generated

  // Pause / cancel
  pauseReason      String?
  cancelReason     String?
  lastPausedAt     DateTime?
  lastResumedAt    DateTime?
  pauseCountMonth  Int          @default(0)  // Pauses used this calendar month
  pauseCountResetAt DateTime?                // When pauseCountMonth was last reset

  // Relations
  student          Student          @relation(fields: [studentId], references: [id])
  parent           ParentProfile    @relation(fields: [parentId], references: [id])
  subject          Subject          @relation(fields: [subjectId], references: [id])
  tutor            TutorProfile     @relation(fields: [tutorId], references: [id])
  sessions         EnrollmentSession[]

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([parentId])
  @@index([studentId])
  @@index([tutorId])
  @@index([status])
}

model EnrollmentSession {
  id               String        @id @default(uuid())
  enrollmentId     String
  status           SessionStatus @default(SCHEDULED)

  // Schedule
  scheduledDate    DateTime      @db.Date
  scheduledStart   String        // "HH:mm"
  scheduledEnd     String        // "HH:mm"

  // Credit deduction
  creditsCharged   Int
  creditDeductedAt DateTime?     // When credits were actually deducted

  // Cancellation
  cancelledAt      DateTime?
  cancelReason     String?

  // Relations
  enrollment       Enrollment    @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  creditTransaction CreditTransaction?

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([enrollmentId, scheduledDate, scheduledStart])
  @@index([enrollmentId])
  @@index([scheduledDate])
  @@index([status])
}

// ============================================
// M9: STRIPE PAYMENTS
// ============================================

model Payment {
  id                    String        @id @default(uuid())
  parentId              String
  creditPackageId       String
  stripeSessionId       String        @unique
  stripePaymentIntentId String?       @unique
  amountInFils          Int           // Snapshot of package price at purchase time
  credits               Int           // Snapshot of credits at purchase time
  currency              String        @default("aed")
  status                PaymentStatus @default(PENDING)
  failureReason         String?
  completedAt           DateTime?

  parent            ParentProfile      @relation(fields: [parentId], references: [id])
  creditPackage     CreditPackage      @relation(fields: [creditPackageId], references: [id])
  creditTransaction CreditTransaction?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([status])
  @@index([createdAt])
}

